# Copy file này thành .env rồi sửa giá trị cho máy bạn.
APP_ENV=development

# Địa chỉ server lắng nghe
ADDR=:8080

# Mức log: debug | info | warn | error
LOG_LEVEL=debug

# Chuỗi kết nối Postgres (BẮT BUỘC). Đổi user/pass/db cho đúng máy bạn.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anngon?sslmode=disable

# Cloudinary (module media) — điền khóa của bạn, KHÔNG commit .env thật
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=anngon
